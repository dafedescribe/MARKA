# MARKA frontend environment (Vite — demo_site/)
# Copy this file to `demo_site/.env` and fill in real values. Never commit `.env`.
# WARNING: every VITE_ variable is bundled into the browser. Put ONLY public values here.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=             # anon/public key only — never the service role key

# Backend API base URL (leave blank in prod if frontend is served by the API itself)
VITE_API_URL=http://localhost:8000

# Paystack PUBLIC key (pk_test_... in dev, pk_live_... in prod)
VITE_PAYSTACK_PUBLIC_KEY=

# Payment provider toggle: "monnify" or "paystack"
VITE_PAYMENT_PROVIDER=monnify

# Monnify public credentials (required when VITE_PAYMENT_PROVIDER=monnify)
VITE_MONNIFY_API_KEY=
VITE_MONNIFY_CONTRACT_CODE=
