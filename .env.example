# MARKA backend environment (repo root)
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Supabase — project URL and keys
SUPABASE_URL=
SUPABASE_KEY=                       # anon/public key
SUPABASE_SERVICE_ROLE_KEY=          # SECRET — server-side only, full DB access

# Auth
JWT_SECRET=                         # REQUIRED — long random string; server refuses to start without it

# CORS — comma-separated list of frontend origins allowed to call this API.
# Add your Vercel URL in prod. Defaults to localhost dev origins if unset.
ALLOWED_ORIGINS=                    # e.g. https://marka.vercel.app,http://localhost:5173

# Paystack (server-side secret key: sk_test_... in dev, sk_live_... in prod)
PAYSTACK_SECRET_KEY=

# Cron secret — protects POST /admin/wipe-expired (the 7-day image wipe).
# Send it as the X-Cron-Secret header from your daily scheduler (e.g. cron-job.org).
CRON_SECRET=                        # long random string
